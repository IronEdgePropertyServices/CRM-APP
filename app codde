<style>
:root {
--bg: #0a0f09;
--surface: #131a11;
--card: #1a2318;
--border: #253022;
--green: #4caf50;
--green-dim: #2d6b30;
--lime: #aedc5a;
--gold: #e0b84a;
--red: #e05a4a;
--blue: #4a9ee0;
--text: #e8f0e5;
--muted: #6a8066;
--tan: #c8bfa8;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;font-size:15px;}

/* LAYOUT */
#app{display:flex;flex-direction:column;height:100vh;height:100dvh;}
#content{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;padding-bottom:80px;}
#content::-webkit-scrollbar{display:none;}

/* TOP BAR */
.topbar{background:var(–surface);padding:52px 20px 14px;border-bottom:1px solid var(–border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.topbar-title{font-family:‘Bebas Neue’,sans-serif;font-size:26px;letter-spacing:2px;color:var(–lime);}
.topbar-sub{font-size:11px;color:var(–muted);letter-spacing:1px;text-transform:uppercase;}
.topbar-action{background:var(–lime);color:#0a0f09;border:none;border-radius:8px;padding:8px 14px;font-family:‘DM Sans’,sans-serif;font-weight:600;font-size:13px;cursor:pointer;}

/* BOTTOM NAV */
.bottom-nav{position:fixed;bottom:0;left:0;right:0;background:var(–surface);border-top:1px solid var(–border);display:flex;z-index:100;padding-bottom:env(safe-area-inset-bottom);}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:10px 4px 8px;cursor:pointer;color:var(–muted);transition:color 0.2s;font-size:10px;letter-spacing:1px;text-transform:uppercase;font-weight:500;gap:4px;}
.nav-item.active{color:var(–lime);}
.nav-icon{font-size:20px;line-height:1;}

/* SCREENS */
.screen{display:none;padding:16px;}
.screen.active{display:block;}

/* SECTION HEADING */
.sh{font-family:‘Bebas Neue’,sans-serif;font-size:22px;letter-spacing:2px;color:var(–text);margin-bottom:4px;}
.sh-sub{font-size:12px;color:var(–muted);margin-bottom:18px;}

/* STAT CARDS */
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:18px;}
.stat-card{background:var(–card);border:1px solid var(–border);border-radius:12px;padding:16px;}
.stat-val{font-family:‘Bebas Neue’,sans-serif;font-size:32px;letter-spacing:1px;line-height:1;}
.stat-label{font-size:11px;color:var(–muted);margin-top:4px;text-transform:uppercase;letter-spacing:1px;}
.stat-card.green .stat-val{color:var(–lime);}
.stat-card.gold .stat-val{color:var(–gold);}
.stat-card.blue .stat-val{color:var(–blue);}
.stat-card.red .stat-val{color:var(–red);}

/* CARDS */
.card{background:var(–card);border:1px solid var(–border);border-radius:12px;padding:16px;margin-bottom:10px;}
.card-row{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;}
.card-name{font-weight:600;font-size:15px;color:var(–text);}
.card-detail{font-size:12px;color:var(–muted);margin-top:3px;}
.badge{display:inline-block;font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;padding:3px 8px;border-radius:4px;}
.badge.active{background:rgba(76,175,80,0.15);color:var(–green);}
.badge.pending{background:rgba(224,184,74,0.15);color:var(–gold);}
.badge.done{background:rgba(74,158,224,0.15);color:var(–blue);}
.badge.overdue{background:rgba(224,90,74,0.15);color:var(–red);}

/* FORM */
.form-group{margin-bottom:14px;}
.form-label{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(–muted);font-weight:500;margin-bottom:6px;display:block;}
.form-input,.form-select,.form-textarea{width:100%;background:#0e1510;border:1px solid var(–border);border-radius:8px;color:var(–text);font-family:‘DM Sans’,sans-serif;font-size:15px;padding:12px 14px;outline:none;transition:border-color 0.2s;-webkit-appearance:none;}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(–lime);}
.form-select option{background:#1a2318;}
.form-textarea{resize:none;height:80px;line-height:1.5;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}

/* BUTTONS */
.btn{width:100%;border:none;border-radius:10px;padding:14px;font-family:‘DM Sans’,sans-serif;font-weight:600;font-size:15px;cursor:pointer;transition:opacity 0.15s,transform 0.1s;}
.btn:active{transform:scale(0.97);}
.btn-primary{background:var(–lime);color:#0a0f09;}
.btn-secondary{background:var(–card);color:var(–text);border:1px solid var(–border);}
.btn-danger{background:rgba(224,90,74,0.15);color:var(–red);border:1px solid rgba(224,90,74,0.2);}
.btn-sms{background:rgba(74,158,224,0.15);color:var(–blue);border:1px solid rgba(74,158,224,0.2);}
.btn-sm{width:auto;padding:8px 14px;font-size:13px;border-radius:8px;}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:200;align-items:flex-end;}
.modal-overlay.open{display:flex;}
.modal{background:var(–surface);border-radius:20px 20px 0 0;padding:24px 20px 40px;width:100%;max-height:90vh;overflow-y:auto;}
.modal-handle{width:40px;height:4px;background:var(–border);border-radius:2px;margin:0 auto 20px;}
.modal-title{font-family:‘Bebas Neue’,sans-serif;font-size:24px;letter-spacing:2px;margin-bottom:18px;color:var(–lime);}

/* TABS */
.tab-bar{display:flex;background:var(–card);border-radius:10px;padding:3px;margin-bottom:16px;gap:3px;}
.tab-btn{flex:1;padding:8px;text-align:center;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;border-radius:8px;cursor:pointer;color:var(–muted);transition:all 0.2s;}
.tab-btn.active{background:var(–lime);color:#0a0f09;}

/* SCRIPT BOX */
.script-box{background:#0e1510;border-left:3px solid var(–lime);border-radius:0 8px 8px 0;padding:16px;font-size:14px;line-height:1.7;color:var(–tan);margin-bottom:12px;}
.script-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(–lime);font-weight:600;margin-bottom:8px;}

/* IF BOX */
.if-box{background:#0a0f09;border:1px solid var(–border);border-radius:8px;padding:14px;margin-bottom:10px;}
.if-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(–gold);font-weight:600;margin-bottom:6px;}
.if-response{font-size:13px;color:var(–tan);line-height:1.6;margin-top:6px;padding-top:6px;border-top:1px solid var(–border);}

/* QUOTE RESULT */
.quote-result-box{background:#0e1510;border:1px solid var(–lime);border-radius:12px;padding:18px;margin-top:16px;display:none;}
.quote-result-box.show{display:block;}
.qr-row{display:flex;justify-content:space-between;font-size:13px;padding:7px 0;border-bottom:1px solid var(–border);}
.qr-row:last-of-type{border:none;}
.qr-label{color:var(–muted);}
.qr-val{color:var(–text);font-weight:500;}
.qr-final{display:flex;justify-content:space-between;align-items:center;border-top:2px solid var(–lime);padding-top:12px;margin-top:8px;}
.qr-final-label{font-family:‘Bebas Neue’,sans-serif;font-size:14px;letter-spacing:2px;color:var(–lime);}
.qr-final-price{font-family:‘Bebas Neue’,sans-serif;font-size:34px;color:var(–lime);}
.qr-script{background:var(–card);border-left:3px solid var(–tan);border-radius:0 8px 8px 0;padding:14px;margin-top:14px;font-size:13px;line-height:1.7;color:var(–tan);}

/* JOB ITEM */
.job-meta{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-top:6px;}
.job-actions{display:flex;gap:8px;margin-top:12px;}
.job-actions button{flex:1;border:none;border-radius:8px;padding:9px;font-size:12px;font-weight:600;cursor:pointer;transition:opacity 0.15s;}

/* TIP */
.tip-box{background:rgba(174,220,90,0.06);border:1px solid rgba(174,220,90,0.2);border-radius:10px;padding:14px 16px;margin-bottom:12px;font-size:13px;color:var(–tan);line-height:1.6;}
.tip-box strong{color:var(–lime);display:block;font-size:10px;letter-spacing:2px;text-transform:uppercase;margin-bottom:4px;}

/* EMPTY STATE */
.empty{text-align:center;padding:48px 20px;color:var(–muted);}
.empty-icon{font-size:48px;margin-bottom:12px;}
.empty-text{font-size:14px;line-height:1.6;}

/* CHECKLIST */
.check-item{display:flex;gap:12px;align-items:flex-start;padding:12px 0;border-bottom:1px solid var(–border);font-size:14px;}
.check-item:last-child{border:none;}
.check-num{width:28px;height:28px;background:var(–green-dim);color:white;font-family:‘Bebas Neue’,sans-serif;font-size:15px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.check-item strong{color:var(–text);display:block;margin-bottom:2px;font-weight:500;}
.check-item span{color:var(–muted);font-size:13px;}

/* REVENUE CHART */
.rev-bar-wrap{margin-bottom:6px;}
.rev-bar-label{display:flex;justify-content:space-between;font-size:12px;color:var(–muted);margin-bottom:4px;}
.rev-bar-track{background:var(–border);border-radius:4px;height:8px;overflow:hidden;}
.rev-bar-fill{background:var(–lime);height:100%;border-radius:4px;transition:width 0.6s ease;}

/* DIVIDER */
.divider{height:1px;background:var(–border);margin:16px 0;}

.mt-10{margin-top:10px;}
.mt-16{margin-top:16px;}
.gap-10{gap:10px;}
.flex{display:flex;}

/* ADDON CHECKBOXES */
.addon-row{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(–border);cursor:pointer;}
.addon-row:last-child{border:none;padding-bottom:0;}
.addon-row input[type=checkbox]{width:18px;height:18px;accent-color:var(–lime);flex-shrink:0;cursor:pointer;}
.addon-name{flex:1;font-size:13px;color:var(–tan);}
.addon-price{font-size:12px;color:var(–lime);font-weight:600;white-space:nowrap;}
</style>

</head>
