// ============ SETTINGS / BACKUP ============
function renderDataSummary(){
const totalEarned = jobs.filter(j=>j.status==='done').reduce((a,j)=>a+j.price,0);
document.getElementById('data-summary').innerHTML = `
<div class="qr-row"><span class="qr-label">Customers saved</span><span class="qr-val" style="color:var(--lime);">${customers.length}</span></div>
<div class="qr-row"><span class="qr-label">Jobs recorded</span><span class="qr-val" style="color:var(--lime);">${jobs.length}</span></div>
<div class="qr-row"><span class="qr-label">Total earned (all time)</span><span class="qr-val" style="color:var(--gold);">$${totalEarned}</span></div>
<div class="qr-row" style="border:none;"><span class="qr-label">Last saved</span><span class="qr-val">${new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</span></div>
`;
}

function exportData(){
const data = { customers, jobs, exportedAt: new Date().toISOString(), version: 1 };
const json = JSON.stringify(data, null, 2);
const blob = new Blob([json], {type:'application/json'});
const url = URL.createObjectURL(blob);
const a = document.createElement('a');
a.href = url;
a.download = `lawn-crm-backup-${new Date().toISOString().split('T')[0]}.json`;
a.click();
URL.revokeObjectURL(url);
}

function exportCSV(){
const headers = ['Name','Phone','Address','Yard Size','Frequency','Rate','Status','Notes'];
const rows = customers.map(c=>[
`"${c.name||''}"`,`"${c.phone||''}"`,`"${c.address||''}"`,
`"${c.size||''}"`,`"${c.frequency||''}"`,c.rate||0,
`"${c.status||''}"`,`"${(c.notes||'').replace(/"/g,"'")}"`
]);
const csv = [headers.join(','), ...rows.map(r=>r.join(','))].join('\n');
const blob = new Blob([csv], {type:'text/csv'});
const url = URL.createObjectURL(blob);
const a = document.createElement('a');
a.href = url;
a.download = `lawn-customers-${new Date().toISOString().split('T')[0]}.csv`;
a.click();
URL.revokeObjectURL(url);
}

function showRawData(){
const data = JSON.stringify({ customers, jobs, exportedAt: new Date().toISOString(), version: 1 });
const box = document.getElementById('raw-data-box');
const btn = document.getElementById('raw-copy-btn');
box.value = data;
box.style.display = 'block';
btn.style.display = 'block';
box.select();
}

function copyRawData(){
const box = document.getElementById('raw-data-box');
box.select();
try {
navigator.clipboard.writeText(box.value).then(()=>alert('✅ Copied! Paste it into your Notes app or email to save.'));
} catch(e){
document.execCommand('copy');
alert('✅ Copied to clipboard!');
}
}

function importFromFile(event){
const file = event.target.files[0];
if(!file) return;
const reader = new FileReader();
reader.onload = e => { processImport(e.target.result); };
reader.readAsText(file);
}

function importFromPaste(){
const text = document.getElementById('import-paste').value.trim();
if(!text){ alert('Please paste your backup data first.'); return; }
processImport(text);
}

function processImport(text){
try {
const data = JSON.parse(text);
let importedCustomers = 0, importedJobs = 0;

if(data.customers && Array.isArray(data.customers)){
data.customers.forEach(ic=>{
// Skip if ID already exists
if(!customers.find(c=>c.id===ic.id)){
customers.push(ic);
importedCustomers++;
}
});
}
if(data.jobs && Array.isArray(data.jobs)){
data.jobs.forEach(ij=>{
if(!jobs.find(j=>j.id===ij.id)){
jobs.push(ij);
importedJobs++;
}
});
}
save();
renderDataSummary();
renderDashboard();
document.getElementById('import-paste').value = '';
alert(`✅ Import complete!\n\n+${importedCustomers} customers\n+${importedJobs} jobs\n\nAll existing data was preserved.`);
} catch(e){
alert('❌ Could not read that data. Make sure you pasted the full backup text without changes.');
}
}

function nukeAll(){
if(!confirm('⚠️ Are you sure? This deletes ALL customers and jobs permanently.\n\nExport a backup first!')) return;
if(!confirm('Last chance — are you absolutely sure?')) return;
customers = [];
jobs = [];
save();
renderDataSummary();
renderDashboard();
alert('All data cleared.');
}

// ============ INIT ============
document.getElementById('topbarAction').style.display='none';
renderDashboard();
showScript('door', document.querySelector('#screen-scripts .tab-btn'));
</script>

