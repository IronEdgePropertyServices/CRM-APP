<script>
// ============ STATE ============
let customers = JSON.parse(localStorage.getItem('lcrm_customers')||'[]');
let jobs = JSON.parse(localStorage.getItem('lcrm_jobs')||'[]');
let currentScreen = 'dashboard';
let lastQuote = null;

function save(){
localStorage.setItem('lcrm_customers', JSON.stringify(customers));
localStorage.setItem('lcrm_jobs', JSON.stringify(jobs));
}

// ============ NAVIGATION ============
function goTo(screen, el){
document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
document.getElementById('screen-'+screen).classList.add('active');
if(el) el.classList.add('active');
currentScreen = screen;

const titles = {
dashboard:['🌿 Dashboard','Your lawn business at a glance'],
customers:['👥 Customers','Manage your client list'],
jobs:['📋 Jobs','Track your schedule'],
quote:['💵 Quote Tool','Build & send quotes on-site'],
scripts:['💬 Scripts','Word-for-word sales scripts'],
settings:['⚙️ Data & Backup','Export, restore & protect your data']
};
document.getElementById('topbarTitle').textContent = titles[screen][0];
document.getElementById('topbarSub').textContent = titles[screen][1];
document.getElementById('topbarAction').style.display = ['customers','jobs'].includes(screen) ? 'block' : 'none';

if(screen==='dashboard') renderDashboard();
if(screen==='customers') renderCustomers();
if(screen==='jobs') renderJobs('upcoming');
if(screen==='scripts') showScript('door', document.querySelector('#screen-scripts .tab-btn'));
if(screen==='settings') renderDataSummary();
}

function topbarActionClick(){
if(currentScreen==='customers') openAddCustomer();
if(currentScreen==='jobs') openAddJob();
}

// ============ MODALS ============
function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}

document.querySelectorAll('.modal-overlay').forEach(m=>{
m.addEventListener('click',e=>{ if(e.target===m) m.classList.remove('open'); });
});

// ============ CUSTOMERS ============
function openAddCustomer(){
document.getElementById('customer-modal-title').textContent = 'Add Customer';
document.getElementById('c-save-btn').textContent = 'Save Customer';
document.getElementById('c-edit-id').value = '';
['c-name','c-phone','c-addr','c-notes'].forEach(id=>document.getElementById(id).value='');
document.getElementById('c-rate').value='';
document.getElementById('c-size').value='Medium';
document.getElementById('c-freq').value='Bi-weekly';
document.getElementById('c-status').value='active';
openModal('modal-customer');
}

function openEditCustomer(id){
const c = customers.find(x=>x.id===id);
if(!c) return;
closeModal('modal-detail');
document.getElementById('customer-modal-title').textContent = 'Edit Customer';
document.getElementById('c-save-btn').textContent = 'Update Customer';
document.getElementById('c-edit-id').value = id;
document.getElementById('c-name').value = c.name;
document.getElementById('c-phone').value = c.phone;
document.getElementById('c-addr').value = c.address||'';
document.getElementById('c-size').value = c.size||'Medium';
document.getElementById('c-freq').value = c.frequency||'Bi-weekly';
document.getElementById('c-rate').value = c.rate||'';
document.getElementById('c-status').value = c.status||'active';
document.getElementById('c-notes').value = c.notes||'';
openModal('modal-customer');
}

function saveCustomer(){
const name = document.getElementById('c-name').value.trim();
const phone = document.getElementById('c-phone').value.trim();
if(!name||!phone){alert('Name and phone are required.');return;}
const editId = document.getElementById('c-edit-id').value;
const data = {
name, phone,
address: document.getElementById('c-addr').value.trim(),
size: document.getElementById('c-size').value,
frequency: document.getElementById('c-freq').value,
rate: parseFloat(document.getElementById('c-rate').value)||0,
status: document.getElementById('c-status').value,
notes: document.getElementById('c-notes').value.trim(),
};
if(editId){
// Update existing
const idx = customers.findIndex(c=>c.id==editId);
if(idx>-1){
customers[idx] = {...customers[idx], ...data};
// Update customerName on linked jobs too
jobs.forEach(j=>{ if(j.customerId==editId) j.customerName=name; });
}
} else {
customers.push({id: Date.now(), ...data, createdAt: new Date().toISOString()});
}
save();
closeModal('modal-customer');
renderCustomers();
renderDashboard();
}

function renderCustomers(){
const el = document.getElementById('customer-list');
if(!customers.length){
el.innerHTML=`<div class="empty"><div class="empty-icon">👥</div><div class="empty-text">No customers yet.<br>Tap <strong>+ Add</strong> to add your first client.</div></div>`;
return;
}
el.innerHTML = customers.map(c=>`
<div class="card" onclick="showCustomer(${c.id})">
<div class="card-row">
<div>
<div class="card-name">${c.name}</div>
<div class="card-detail">${c.address||'No address'} · ${c.frequency}</div>
<div class="card-detail" style="margin-top:2px;">${c.phone}</div>
</div>
<div style="text-align:right;">
<span class="badge ${c.status}">${c.status}</span>
${c.rate ? `<div style="font-family:'Bebas Neue',sans-serif;font-size:20px;color:var(--lime);margin-top:6px;">$${c.rate}</div>` : ''}
</div>
</div>
</div>
`).join('');
}

function showCustomer(id){
const c = customers.find(x=>x.id===id);
if(!c) return;
const cJobs = jobs.filter(j=>j.customerId===id).sort((a,b)=>b.date.localeCompare(a.date));
const earned = cJobs.filter(j=>j.status==='done').reduce((a,j)=>a+j.price,0);
const upcomingJobs = cJobs.filter(j=>j.status==='upcoming');

const jobHistoryHTML = cJobs.length ? cJobs.slice(0,5).map(j=>{
const isOverdue = j.status==='upcoming' && j.date < new Date().toISOString().split('T')[0];
const badge = isOverdue ? 'overdue' : j.status;
return `<div style="display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--border);">
<div>
<div style="font-size:13px;font-weight:500;color:var(--text);">${j.services}</div>
<div style="font-size:11px;color:var(--muted);margin-top:2px;">📅 ${formatDate(j.date)}</div>
</div>
<div style="text-align:right;">
<div style="font-family:'Bebas Neue',sans-serif;font-size:18px;color:var(--lime);">$${j.price}</div>
<span class="badge ${badge}" style="font-size:9px;">${isOverdue?'overdue':j.status}</span>
</div>
</div>`;
}).join('') : `<div style="font-size:13px;color:var(--muted);padding:10px 0;">No jobs yet.</div>`;

document.getElementById('detail-content').innerHTML = `
<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:16px;">
<div>
<div class="modal-title" style="margin-bottom:4px;">${c.name}</div>
<span class="badge ${c.status}">${c.status}</span>
</div>
<button onclick="openEditCustomer(${c.id})" style="background:rgba(174,220,90,0.12);border:1px solid rgba(174,220,90,0.3);color:var(--lime);border-radius:8px;padding:8px 14px;font-size:13px;font-weight:600;cursor:pointer;flex-shrink:0;">✏️ Edit</button>
</div>

<div class="card" style="margin-bottom:12px;">
<div class="card-row">
<span class="card-detail">📞 Phone</span>
<span style="font-size:14px;">${c.phone}</span>
</div>
${c.address?`<div class="card-row" style="margin-top:8px;"><span class="card-detail">📍 Address</span><span style="font-size:13px;">${c.address}</span></div>`:''}
<div class="card-row" style="margin-top:8px;"><span class="card-detail">🌿 Yard</span><span style="font-size:13px;">${c.size||'—'} · ${c.frequency||'—'}</span></div>
<div class="card-row" style="margin-top:8px;"><span class="card-detail">💵 Rate</span><span style="font-size:14px;color:var(--lime);font-weight:600;">${c.rate?'$'+c.rate+'/visit':'Not set'}</span></div>
${c.notes?`<div style="margin-top:10px;padding-top:10px;border-top:1px solid var(--border);font-size:13px;color:var(--tan);">📝 ${c.notes}</div>`:''}
</div>

<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:14px;">
<div class="stat-card blue"><div class="stat-val">${cJobs.length}</div><div class="stat-label">Jobs</div></div>
<div class="stat-card gold"><div class="stat-val">$${earned}</div><div class="stat-label">Earned</div></div>
<div class="stat-card red"><div class="stat-val">${upcomingJobs.length}</div><div class="stat-label">Pending</div></div>
</div>

<div style="display:flex;gap:8px;margin-bottom:12px;">
<a href="tel:${c.phone}" class="btn btn-secondary btn-sm" style="flex:1;text-decoration:none;text-align:center;">📞 Call</a>
<a href="sms:${c.phone}" class="btn btn-sms btn-sm" style="flex:1;text-decoration:none;text-align:center;">💬 Text</a>
<button class="btn btn-primary btn-sm" style="flex:1;" onclick="scheduleJobFor(${c.id})">📋 Job</button>
</div>

<div style="font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:2px;color:var(--muted);margin-bottom:4px;">JOB HISTORY</div>
<div style="border-top:1px solid var(--border);">${jobHistoryHTML}</div>
${cJobs.length>5?`<div style="font-size:12px;color:var(--muted);text-align:center;padding:8px;">+${cJobs.length-5} more jobs</div>`:''}

<div style="margin-top:16px;">
<button class="btn btn-danger" onclick="deleteCustomer(${c.id})">🗑 Delete Customer</button>
</div>
`;
openModal('modal-detail');
}

function scheduleJobFor(customerId){
closeModal('modal-detail');
openAddJob();
setTimeout(()=>{
const sel = document.getElementById('j-customer');
sel.value = customerId;
sel.dispatchEvent(new Event('change'));
}, 150);
}

function deleteCustomer(id){
if(!confirm('Delete this customer and all their jobs?')) return;
customers = customers.filter(c=>c.id!==id);
jobs = jobs.filter(j=>j.customerId!==id);
save();
closeModal('modal-detail');
renderCustomers();
renderDashboard();
}

// ============ JOBS ============
function openAddJob(){
const sel = document.getElementById('j-customer');
sel.innerHTML = '<option value="">Select customer...</option>' +
customers.map(c=>`<option value="${c.id}">${c.name}</option>`).join('');
document.getElementById('j-date').value = new Date().toISOString().split('T')[0];
document.getElementById('j-price').value = '';
document.getElementById('j-notes').value = '';
openModal('modal-job');
}

document.getElementById('j-customer').addEventListener('change',function(){
const c = customers.find(x=>x.id==this.value);
if(c && c.rate) document.getElementById('j-price').value = c.rate;
});

function saveJob(){
const custId = parseInt(document.getElementById('j-customer').value);
const date = document.getElementById('j-date').value;
const price = parseFloat(document.getElementById('j-price').value)||0;
if(!custId||!date){alert('Please select a customer and date.');return;}
const cust = customers.find(c=>c.id===custId);
jobs.push({
id: Date.now(),
customerId: custId,
customerName: cust?cust.name:'Unknown',
date,
price,
services: document.getElementById('j-services').value,
notes: document.getElementById('j-notes').value.trim(),
status: 'upcoming'
});
save();
closeModal('modal-job');
renderJobs('upcoming');
renderDashboard();
}

let jobFilter = 'upcoming';
function filterJobs(f, el){
jobFilter = f;
document.querySelectorAll('#screen-jobs .tab-btn').forEach(b=>b.classList.remove('active'));
if(el) el.classList.add('active');
renderJobs(f);
}

function renderJobs(filter){
const el = document.getElementById('job-list');
let list = [...jobs].sort((a,b)=>a.date.localeCompare(b.date));
if(filter==='upcoming') list = list.filter(j=>j.status==='upcoming');
if(filter==='done') list = list.filter(j=>j.status==='done');

if(!list.length){
el.innerHTML=`<div class="empty"><div class="empty-icon">📋</div><div class="empty-text">No ${filter==='all'?'':filter} jobs.<br>${filter==='upcoming'?'Tap <strong>+ Add</strong> to schedule one.':''}</div></div>`;
return;
}

el.innerHTML = list.map(j=>{
const today = new Date().toISOString().split('T')[0];
const isOverdue = j.status==='upcoming' && j.date < today;
const statusBadge = isOverdue ? 'overdue' : j.status;
const displayDate = formatDate(j.date);
return `
<div class="card">
<div class="card-row">
<div>
<div class="card-name">${j.customerName}</div>
<div class="card-detail">${j.services}</div>
</div>
<div style="text-align:right;">
<div style="font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--lime);">$${j.price}</div>
<span class="badge ${statusBadge}">${isOverdue?'overdue':j.status}</span>
</div>
</div>
<div class="job-meta">
<span style="font-size:12px;color:var(--muted);">📅 ${displayDate}</span>
${j.notes?`<span style="font-size:12px;color:var(--muted);">· ${j.notes.substring(0,30)}${j.notes.length>30?'...':''}</span>`:''}
</div>
${j.status==='upcoming' ? `
<div class="job-actions">
<button onclick="markDone(${j.id})" style="background:rgba(76,175,80,0.15);color:var(--green);">✓ Mark Done</button>
<button onclick="deleteJob(${j.id})" style="background:rgba(224,90,74,0.1);color:var(--red);">✕ Delete</button>
</div>` : ''}
</div>
`;
}).join('');
}

function markDone(id){
const j = jobs.find(x=>x.id===id);
if(j){ j.status='done'; save(); renderJobs(jobFilter); renderDashboard(); }
}
function deleteJob(id){
jobs = jobs.filter(j=>j.id!==id);
save(); renderJobs(jobFilter); renderDashboard();
}

function formatDate(d){
const date = new Date(d+'T12:00:00');
return date.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'});
}

// ============ DASHBOARD ============
function renderDashboard(){
const today = new Date().toISOString().split('T')[0];
const now = new Date();
const monthStart = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().split('T')[0];

const monthRevenue = jobs.filter(j=>j.status==='done'&&j.date>=monthStart).reduce((a,j)=>a+j.price,0);
const doneCount = jobs.filter(j=>j.status==='done').length;
const pendingCount = jobs.filter(j=>j.status==='upcoming').length;

document.getElementById('stat-customers').textContent = customers.length;
document.getElementById('stat-revenue').textContent = '$'+monthRevenue;
document.getElementById('stat-jobs').textContent = doneCount;
document.getElementById('stat-pending').textContent = pendingCount;

// Upcoming jobs
const upcoming = jobs.filter(j=>j.status==='upcoming').sort((a,b)=>a.date.localeCompare(b.date)).slice(0,3);
const du = document.getElementById('dash-upcoming');
if(!upcoming.length){
du.innerHTML=`<div style="color:var(--muted);font-size:13px;padding:10px 0;">No upcoming jobs scheduled.</div>`;
} else {
du.innerHTML = upcoming.map(j=>`
<div class="card" style="margin-bottom:8px;">
<div class="card-row">
<div><div class="card-name">${j.customerName}</div><div class="card-detail">📅 ${formatDate(j.date)} · ${j.services}</div></div>
<div style="font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--lime);">$${j.price}</div>
</div>
</div>
`).join('');
}

// Recent customers
const recent = [...customers].reverse().slice(0,3);
const dr = document.getElementById('dash-recent');
if(!recent.length){
dr.innerHTML=`<div style="color:var(--muted);font-size:13px;padding:10px 0;">No customers yet.</div>`;
} else {
dr.innerHTML = recent.map(c=>`
<div class="card" style="margin-bottom:8px;" onclick="goTo('customers',document.querySelectorAll('.nav-item')[1])">
<div class="card-row">
<div><div class="card-name">${c.name}</div><div class="card-detail">${c.address||c.phone} · ${c.frequency}</div></div>
<span class="badge ${c.status}">${c.status}</span>
</div>
</div>
`).join('');
}

// Revenue chart (last 6 weeks)
const weeks = [];
for(let i=5;i>=0;i--){
const d = new Date(); d.setDate(d.getDate() - i*7);
const wStart = new Date(d); wStart.setDate(d.getDate()-6);
const label = 'Wk '+(6-i);
const rev = jobs.filter(j=>{
if(j.status!=='done') return false;
const jd = j.date;
return jd >= wStart.toISOString().split('T')[0] && jd <= d.toISOString().split('T')[0];
}).reduce((a,j)=>a+j.price,0);
weeks.push({label, rev});
}
const maxRev = Math.max(...weeks.map(w=>w.rev), 1);
document.getElementById('dash-chart').innerHTML = weeks.map(w=>`
<div class="rev-bar-wrap">
<div class="rev-bar-label"><span>${w.label}</span><span style="color:var(--lime);">$${w.rev}</span></div>
<div class="rev-bar-track"><div class="rev-bar-fill" style="width:${Math.round(w.rev/maxRev*100)}%"></div></div>
</div>
`).join('');
}

// ============ QUOTE TOOL ============
function calcQuote(showResult){
const size = document.getElementById('q-size').value;
const cond = document.getElementById('q-cond').value;
const obs = document.getElementById('q-obs').value;
const slope = document.getElementById('q-slope').value;
const ctype = document.getElementById('q-ctype').value;

const bases={small:[35,50],medium:[55,75],large:[80,120],xlarge:[120,180]};
let [lo,hi]=bases[size];
let condAdj=0,condLabel='+$0';
if(cond==='overgrown'){condAdj=15;condLabel='+$15';}
if(cond==='very'){condAdj=30;condLabel='+$30';}
let diffAdj=(slope==='steep'?15:slope==='some'?7:0)+(obs==='many'?15:obs==='some'?7:0);
let diffLabel = diffAdj>0?`+$${diffAdj}`:'+$0';
let disc=ctype==='senior'?10:ctype==='recurring'?5:0;
let discLabel=disc>0?`-$${disc}`:'None';

// Collect checked add-ons
const checked = [...document.querySelectorAll('.addon-cb:checked')];
let addonLo=0, addonHi=0;
const addonNames=[];
checked.forEach(cb=>{
addonLo+=parseInt(cb.dataset.lo);
addonHi+=parseInt(cb.dataset.hi);
addonNames.push(cb.dataset.label);
});

let flo=lo+condAdj+diffAdj+addonLo-disc;
let fhi=hi+condAdj+diffAdj+addonHi-disc;
let mid=Math.round((flo+fhi)/2);

document.getElementById('qr-base').textContent=`$${lo}–$${hi}`;
document.getElementById('qr-cond').textContent=condLabel;
document.getElementById('qr-diff').textContent=diffLabel;
document.getElementById('qr-disc').textContent=discLabel;
document.getElementById('qr-final').textContent=`$${flo}–$${fhi}`;

// Show add-ons line items
const addonListEl = document.getElementById('qr-addons-list');
if(checked.length){
addonListEl.innerHTML = checked.map(cb=>`
<div class="qr-row"><span class="qr-label">${cb.dataset.label}</span><span class="qr-val">+$${cb.dataset.lo}–${cb.dataset.hi}</span></div>
`).join('');
} else {
addonListEl.innerHTML='';
}

// Services summary
const baseService = 'Mow + Trim + Blow';
const allServices = addonNames.length ? baseService+' · '+addonNames.join(' · ') : baseService;
document.getElementById('qr-services-summary').textContent = '📋 '+allServices;

const servicesText = addonNames.length
? `mowing, trimming & blowing plus: ${addonNames.join(', ')}`
: `mowing, trimming, and blowing`;
document.getElementById('qr-script').textContent=`"Based on what I see, for ${servicesText} I'd charge $${flo} to $${fhi}. Right around $${mid} is the sweet spot. Want me to put you on the schedule?"`;

lastQuote = {lo:flo, hi:fhi, mid, services:allServices};
if(showResult) document.getElementById('qr-box').classList.add('show');
}

function sendSMS(){
const phone = document.getElementById('q-phone').value.trim().replace(/\D/g,'');
if(!lastQuote){alert('Calculate a quote first.');return;}
const servicesList = lastQuote.services || 'mow, trim & blow';
const msg = encodeURIComponent(`Hi! Based on your yard, here's my quote:\n\nServices: ${servicesList}\nPrice: $${lastQuote.lo}–$${lastQuote.hi}\n\nWant to get scheduled? — [Your Name]`);
window.location.href = `sms:${phone}&body=${msg}`;
}

function saveQuoteAsJob(){
if(!lastQuote){alert('Calculate a quote first.');return;}
if(!customers.length){alert('Add a customer first.');return;}
closeModal && closeModal('qr-box');
openAddJob();
setTimeout(()=>{ document.getElementById('j-price').value=lastQuote.mid; },100);
}

